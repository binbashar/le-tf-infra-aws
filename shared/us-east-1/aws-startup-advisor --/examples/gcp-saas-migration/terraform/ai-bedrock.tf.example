# ─────────────────────────────────────────────────────────────────────────────
# AI migration — OpenAI (gpt-4o) → Amazon Bedrock (Claude)
#
# Detected from app code during Discover, not from Terraform: the summary
# worker calls the OpenAI Chat Completions API (gpt-4o) to generate meeting
# summaries. There is no `google_*` resource for this — it's an SDK call.
#
# ⚠️  Model mapping is COMPATIBILITY-GUIDED, not 1:1 parity. Re-validate prompts,
#     tool-calling behavior, and eval metrics before cutover. gpt-4o → Claude
#     (Sonnet family) is the closest-fit for summary/quality workloads; the
#     plugin's honest-cost note: at the gpt-4o tier, OpenAI can be ~29% cheaper
#     per token, so the migration case here is provider consolidation + IAM auth
#     (no third-party API key), not raw token cost.
# ─────────────────────────────────────────────────────────────────────────────

# Bedrock uses IAM — no API key secret. The former GCP `openai-api-key` Secret
# Manager secret is retired; the summary worker's task role gets InvokeModel.
data "aws_iam_policy_document" "bedrock_invoke" {
  statement {
    sid    = "InvokeClaudeForSummaries"
    effect = "Allow"
    actions = [
      "bedrock:InvokeModel",
      "bedrock:InvokeModelWithResponseStream",
    ]
    # Pin to the summarization model family; widen only with review.
    resources = [
      "arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-*",
    ]
  }
}

resource "aws_iam_policy" "bedrock_invoke" {
  name   = "${local.name}-bedrock-invoke"
  policy = data.aws_iam_policy_document.bedrock_invoke.json
}

# The summary worker (SQS consumer). Kept on Fargate rather than Lambda to allow
# streaming long summaries and to reuse the API container image/toolchain.
resource "aws_iam_role_policy_attachment" "summary_worker_bedrock" {
  role       = aws_iam_role.summary_worker.name
  policy_arn = aws_iam_policy.bedrock_invoke.arn
}

# ── App-code change (illustrative, not Terraform) ────────────────────────────
# The Generate phase also emits an adapter + test harness under ai-migration/.
# The call site changes from:
#
#     # before (OpenAI SDK)
#     client.chat.completions.create(model="gpt-4o", messages=[...])
#
# to Bedrock (Converse API — provider-agnostic message shape):
#
#     # after (boto3 Bedrock Runtime)
#     bedrock.converse(
#         modelId="anthropic.claude-sonnet-4-6",   # closest-fit for gpt-4o
#         messages=[...],
#     )
#
# Cut over behind a feature flag, run the eval harness on a golden set of
# meeting transcripts, and compare summary quality + latency before flipping
# 100% of traffic. See ../MIGRATION_GUIDE.md → "AI cutover".
