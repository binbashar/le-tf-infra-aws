# ─────────────────────────────────────────────────────────────────────────────
# Outputs — the handful of values needed for DNS cutover and app config.
# ─────────────────────────────────────────────────────────────────────────────

output "alb_dns_name" {
  description = "ALB hostname — point the Route 53 record here at cutover."
  value       = aws_lb.api.dns_name
}

output "route53_name_servers" {
  description = "Delegate the meridian.app zone to these NS records at the registrar."
  value       = aws_route53_zone.primary.name_servers
}

output "aurora_writer_endpoint" {
  description = "Aurora writer endpoint for the app DB connection string."
  value       = aws_rds_cluster.postgres.endpoint
}

output "aurora_reader_endpoint" {
  description = "Aurora reader endpoint for read replicas."
  value       = aws_rds_cluster.postgres.reader_endpoint
}

output "redis_primary_endpoint" {
  description = "ElastiCache Redis primary endpoint."
  value       = aws_elasticache_replication_group.cache.primary_endpoint_address
}

output "uploads_bucket" {
  description = "S3 bucket that replaces the GCS uploads bucket."
  value       = aws_s3_bucket.uploads.bucket
}

output "summary_jobs_topic_arn" {
  description = "SNS topic ARN that replaces the Pub/Sub summary-jobs topic."
  value       = aws_sns_topic.summary_jobs.arn
}
