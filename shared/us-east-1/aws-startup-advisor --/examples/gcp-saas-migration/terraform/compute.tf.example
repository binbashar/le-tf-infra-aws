# ─────────────────────────────────────────────────────────────────────────────
# Compute
#   google_cloud_run_v2_service (always-on HTTP)   → ECS Fargate + ALB
#   google_cloudfunctions2_function (event, <15m)  → Lambda
# ─────────────────────────────────────────────────────────────────────────────

# ── ALB (google_compute_forwarding_rule → ALB) ──────────────────────────────
resource "aws_lb" "api" {
  name               = "${local.name}-api"
  load_balancer_type = "application"
  subnets            = module.vpc.public_subnets
  security_groups    = [aws_security_group.alb.id]
}

resource "aws_security_group" "alb" {
  name_prefix = "${local.name}-alb-"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# ── API service on Fargate (Cloud Run → Fargate) ────────────────────────────
# Always-on + cold-start sensitive (min_instance_count = 1 in GCP) → Fargate,
# not Lambda. desired_count mirrors the always-on requirement.
resource "aws_ecs_cluster" "main" {
  name = "${local.name}-cluster"
}

resource "aws_ecs_service" "api" {
  name            = "${local.name}-api"
  cluster         = aws_ecs_cluster.main.id
  task_definition = aws_ecs_task_definition.api.arn
  desired_count   = 2 # dev could run 1; prod ≥2 across AZs
  launch_type     = "FARGATE"

  network_configuration {
    subnets         = module.vpc.private_subnets
    security_groups = [aws_security_group.api.id]
  }

  load_balancer {
    target_group_arn = aws_lb_target_group.api.arn
    container_name   = "api"
    container_port   = 8080
  }
}

resource "aws_cloudwatch_log_group" "api" {
  name              = "/ecs/${local.name}-api"
  retention_in_days = 30
}

resource "aws_ecs_task_definition" "api" {
  family                   = "${local.name}-api"
  requires_compatibilities = ["FARGATE"]
  network_mode             = "awsvpc"
  cpu                      = 512  # 0.5 vCPU (dev); prod → 1024 to match GCP "cpu = 1"
  memory                   = 1024 # prod → match GCP 512Mi limit + headroom

  container_definitions = jsonencode([
    {
      name         = "api"
      image        = "${aws_ecr_repository.api.repository_url}:latest"
      essential    = true
      portMappings = [{ containerPort = 8080 }]
      # Ship stdout/stderr to CloudWatch Logs (the awslogs driver needs the
      # log group to exist — created above).
      logConfiguration = {
        logDriver = "awslogs"
        options = {
          "awslogs-group"         = aws_cloudwatch_log_group.api.name
          "awslogs-region"        = local.region
          "awslogs-stream-prefix" = "api"
        }
      }
    }
  ])

  execution_role_arn = aws_iam_role.ecs_execution.arn
  task_role_arn      = aws_iam_role.ecs_task.arn
}

resource "aws_lb_target_group" "api" {
  name        = "${local.name}-api"
  port        = 8080
  protocol    = "HTTP"
  vpc_id      = module.vpc.vpc_id
  target_type = "ip"
}

# TLS cert for the ALB, DNS-validated against the Route 53 zone (see data.tf).
resource "aws_acm_certificate" "api" {
  domain_name       = "meridian.app"
  validation_method = "DNS"
}

resource "aws_route53_record" "api_cert_validation" {
  for_each = {
    for dvo in aws_acm_certificate.api.domain_validation_options : dvo.domain_name => {
      name   = dvo.resource_record_name
      type   = dvo.resource_record_type
      record = dvo.resource_record_value
    }
  }

  zone_id = aws_route53_zone.primary.zone_id
  name    = each.value.name
  type    = each.value.type
  records = [each.value.record]
  ttl     = 60
}

resource "aws_acm_certificate_validation" "api" {
  certificate_arn         = aws_acm_certificate.api.arn
  validation_record_fqdns = [for r in aws_route53_record.api_cert_validation : r.fqdn]
}

# HTTPS listener binds the ALB to the target group — without it the ALB never
# forwards traffic to the Fargate service.
resource "aws_lb_listener" "https" {
  load_balancer_arn = aws_lb.api.arn
  port              = 443
  protocol          = "HTTPS"
  ssl_policy        = "ELBSecurityPolicy-TLS13-1-2-2021-06"
  certificate_arn   = aws_acm_certificate_validation.api.certificate_arn

  default_action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.api.arn
  }
}

resource "aws_security_group" "api" {
  name_prefix = "${local.name}-api-"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port       = 8080
    to_port         = 8080
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
  }
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_ecr_repository" "api" {
  name = "${local.name}-api"
}

# ── Webhook handler on Lambda (Cloud Functions → Lambda) ────────────────────
# Event-driven, 120s timeout, Python 3.12 → clean Lambda fit.
resource "aws_lambda_function" "webhooks" {
  function_name = "${local.name}-webhooks"
  runtime       = "python3.12"
  handler       = "handler.handle_webhook"
  timeout       = 120
  memory_size   = 256

  filename = "webhooks.zip" # placeholder; wire to real artifact in CI
  role     = aws_iam_role.lambda_webhooks.arn
}
