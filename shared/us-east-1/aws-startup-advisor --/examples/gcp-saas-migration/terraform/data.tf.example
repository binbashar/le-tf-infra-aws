# ─────────────────────────────────────────────────────────────────────────────
# Data stores, cache, storage, messaging, secrets, DNS
#   google_sql_database_instance (PostgreSQL) → RDS Aurora PostgreSQL
#   google_redis_instance                     → ElastiCache Redis
#   google_storage_bucket                     → S3
#   google_pubsub_topic                       → SNS (+ SQS worker queue)
#   google_secret_manager_secret              → Secrets Manager
#   google_dns_managed_zone                   → Route 53
# ─────────────────────────────────────────────────────────────────────────────

# ── Aurora PostgreSQL (Cloud SQL POSTGRES_15, REGIONAL/HA) ──────────────────
# GCP instance is REGIONAL (HA) at 2 vCPU / 7.5 GB → provisioned Aurora with a
# reader for prod. Dev/staging would use Serverless v2 (min 0.5 ACU).
resource "aws_rds_cluster" "postgres" {
  cluster_identifier          = "${local.name}-pg"
  engine                      = "aurora-postgresql"
  engine_version              = "15.4"
  database_name               = "meridian"
  master_username             = "meridian_admin"
  manage_master_user_password = true # → Secrets Manager, no plaintext

  db_subnet_group_name   = aws_db_subnet_group.main.name
  vpc_security_group_ids = [aws_security_group.postgres.id]

  # prod: provisioned, HA via reader in a second AZ (mirrors GCP REGIONAL)
  # dev:  swap the two instances below for a single Serverless v2 (min 0.5 ACU)
}

resource "aws_rds_cluster_instance" "postgres" {
  count              = 2 # writer + reader (HA); dev → 1
  identifier         = "${local.name}-pg-${count.index}"
  cluster_identifier = aws_rds_cluster.postgres.id
  instance_class     = "db.t4g.medium" # ~2 vCPU / 4 GB; prod tune to workload
  engine             = aws_rds_cluster.postgres.engine
  engine_version     = aws_rds_cluster.postgres.engine_version
}

resource "aws_db_subnet_group" "main" {
  name       = "${local.name}-db"
  subnet_ids = module.vpc.private_subnets
}

resource "aws_security_group" "postgres" {
  name_prefix = "${local.name}-pg-"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.api.id]
  }
}

# ── ElastiCache Redis (Memorystore STANDARD_HA) ─────────────────────────────
resource "aws_elasticache_replication_group" "cache" {
  replication_group_id       = "${local.name}-cache"
  description                = "Meridian cache (from Memorystore STANDARD_HA)"
  engine                     = "redis"
  node_type                  = "cache.t4g.micro" # dev; prod → cache.t4g.small+
  num_cache_clusters         = 2                 # HA (multi-AZ) mirrors STANDARD_HA
  automatic_failover_enabled = true

  subnet_group_name  = aws_elasticache_subnet_group.main.name
  security_group_ids = [aws_security_group.redis.id]
}

resource "aws_elasticache_subnet_group" "main" {
  name       = "${local.name}-cache"
  subnet_ids = module.vpc.private_subnets
}

resource "aws_security_group" "redis" {
  name_prefix = "${local.name}-redis-"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.api.id]
  }
}

# ── S3 (Cloud Storage uploads bucket) ───────────────────────────────────────
resource "aws_s3_bucket" "uploads" {
  bucket = "${local.name}-uploads"
}

resource "aws_s3_bucket_public_access_block" "uploads" {
  bucket                  = aws_s3_bucket.uploads.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_versioning" "uploads" {
  bucket = aws_s3_bucket.uploads.id
  versioning_configuration {
    status = "Enabled"
  }
}

# ── SNS + SQS (Pub/Sub summary_jobs topic → fan-out + worker queue) ─────────
resource "aws_sns_topic" "summary_jobs" {
  name = "${local.name}-summary-jobs"
}

resource "aws_sqs_queue" "summary_worker" {
  name                       = "${local.name}-summary-worker"
  visibility_timeout_seconds = 300 # ≥ summary worker max runtime

  # Route messages that fail processing maxReceiveCount times to the DLQ.
  redrive_policy = jsonencode({
    deadLetterTargetArn = aws_sqs_queue.summary_worker_dlq.arn
    maxReceiveCount     = 5
  })
}

resource "aws_sqs_queue" "summary_worker_dlq" {
  name = "${local.name}-summary-worker-dlq"
}

resource "aws_sns_topic_subscription" "summary_to_sqs" {
  topic_arn = aws_sns_topic.summary_jobs.arn
  protocol  = "sqs"
  endpoint  = aws_sqs_queue.summary_worker.arn
}

# Allow the SNS topic to deliver to the SQS queue. Without this policy SNS
# cannot call sqs:SendMessage and deliveries fail silently.
resource "aws_sqs_queue_policy" "summary_worker" {
  queue_url = aws_sqs_queue.summary_worker.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect    = "Allow"
        Principal = { Service = "sns.amazonaws.com" }
        Action    = "sqs:SendMessage"
        Resource  = aws_sqs_queue.summary_worker.arn
        Condition = {
          ArnEquals = { "aws:SourceArn" = aws_sns_topic.summary_jobs.arn }
        }
      }
    ]
  })
}

# ── Secrets Manager (Secret Manager secrets) ────────────────────────────────
# db-password is handled by Aurora's manage_master_user_password above.
# The former openai-api-key secret is retired — Bedrock uses IAM, no API key.
# See ai-bedrock.tf.example.
resource "aws_secretsmanager_secret" "app" {
  name = "${local.name}/app"
}

# ── Route 53 (Cloud DNS managed zone) ───────────────────────────────────────
resource "aws_route53_zone" "primary" {
  name = "meridian.app"
}
